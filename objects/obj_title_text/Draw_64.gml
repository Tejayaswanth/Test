/// @description Execute Code
// 1. Set the font you created
draw_set_font(Begin); 

// 2. Set the text color 
draw_set_color(c_white); 

// 3. Center the text alignment
draw_set_halign(fa_center); 

// 4. Draw the text
draw_text(display_get_gui_width() / 2, display_get_gui_height() / 2, "TO START THIS GAME SEARCH\nBENEATH THE SURFACE !!..............");